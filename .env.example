DATABASE_URL="postgresql://postgres:postgres@localhost:5432/elderly_care_ai?schema=public"
# Optional but recommended for Prisma schema push or migrations on hosted databases
DATABASE_URL_UNPOOLED=""

AUTH_SECRET="change-this-to-a-long-random-secret"
NEXTAUTH_SECRET="change-this-to-a-long-random-secret"
NEXTAUTH_URL="http://localhost:3000"
APP_URL="http://localhost:3000"
# Production example:
# NEXTAUTH_URL="https://seniorhealthcheck.xyz"
# APP_URL="https://seniorhealthcheck.xyz"
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
AUTH_FACEBOOK_ID=""
AUTH_FACEBOOK_SECRET=""
AUTH_LINE_ID=""
AUTH_LINE_SECRET=""

# Optional: use Vercel Blob in production for persistent image storage
BLOB_READ_WRITE_TOKEN=""

# SMS Notification Configuration (Twilio)
# Get these from: https://www.twilio.com/console
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""

# Security: Cron job secret to prevent unauthorized access
CRON_SECRET="change-this-to-a-long-random-secret"

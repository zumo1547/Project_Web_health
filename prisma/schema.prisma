generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  DOCTOR
  CAREGIVER
  ELDERLY
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum AiScanType {
  MEDICINE_IMAGE
  BLOOD_PRESSURE_IMAGE
}

enum AiScanStatus {
  PENDING
  COMPLETED
  FAILED
  REVIEWED
}

enum CaseStatus {
  SELF_SERVICE
  WAITING_DOCTOR
  IN_REVIEW
  COMPLETED
}

enum DoctorCaseStatus {
  ACTIVE
  COMPLETED
}

enum AiHealthMessageRole {
  USER
  ASSISTANT
}

model User {
  id                     String                @id @default(cuid())
  name                   String
  email                  String                @unique
  passwordHash           String
  role                   Role                  @default(ELDERLY)
  createdAt              DateTime              @default(now())
  updatedAt              DateTime              @updatedAt
  doctorPatients         DoctorPatient[]       @relation("DoctorUser")
  caregiverPatients      ElderlyCaregiver[]    @relation("CaregiverUser")
  elderlyProfile         ElderlyProfile?       @relation("ElderlyUserProfile")
  createdBloodPressures  BloodPressureRecord[] @relation("BloodPressureCreator")
  uploadedMedicineImages MedicineImage[]       @relation("MedicineUploader")
  reviewedScans          AiScan[]              @relation("AiScanReviewer")
  sentChatMessages       ChatMessage[]         @relation("ChatSender")
  auditLogs              AuditLog[]
  accounts               Account[]
  sessions               Session[]
}

model ElderlyProfile {
  id                String              @id @default(cuid())
  firstName         String
  lastName          String
  nationalId        String?             @unique
  elderlyUserId     String?             @unique
  birthDate         DateTime?
  gender            Gender?
  phone             String?
  address           String?
  allergies         String?
  chronicDiseases   String?
  notes             String?
  lastKnownLatitude Float?
  lastKnownLongitude Float?
  lastKnownLocationLabel String?
  lastKnownLocationUpdatedAt DateTime?
  caseStatus        CaseStatus          @default(SELF_SERVICE)
  doctorRequestNote String?
  doctorRequestedAt DateTime?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  elderlyUser      User?                 @relation("ElderlyUserProfile", fields: [elderlyUserId], references: [id], onDelete: SetNull)
  bloodPressures   BloodPressureRecord[]
  medicineImages   MedicineImage[]
  aiScans          AiScan[]
  doctors          DoctorPatient[]
  caregivers       ElderlyCaregiver[]
  chatMessages     ChatMessage[]
  aiHealthMessages AiHealthMessage[]
}

model DoctorPatient {
  id          String           @id @default(cuid())
  doctorId    String
  elderlyId   String
  status      DoctorCaseStatus @default(ACTIVE)
  closedNote  String?
  completedAt DateTime?
  createdAt   DateTime         @default(now())

  doctor  User           @relation("DoctorUser", fields: [doctorId], references: [id], onDelete: Cascade)
  elderly ElderlyProfile @relation(fields: [elderlyId], references: [id], onDelete: Cascade)

  @@unique([doctorId, elderlyId])
}

model ElderlyCaregiver {
  id          String         @id @default(cuid())
  caregiverId String
  elderlyId   String
  createdAt   DateTime       @default(now())

  caregiver User           @relation("CaregiverUser", fields: [caregiverId], references: [id], onDelete: Cascade)
  elderly   ElderlyProfile @relation(fields: [elderlyId], references: [id], onDelete: Cascade)

  @@unique([caregiverId, elderlyId])
}

model BloodPressureRecord {
  id             String         @id @default(cuid())
  elderlyId      String
  systolic       Int
  diastolic      Int
  pulse          Int?
  measuredAt     DateTime
  sourceImageUrl String?
  note           String?
  createdById    String?
  createdAt      DateTime       @default(now())
  elderly        ElderlyProfile @relation(fields: [elderlyId], references: [id], onDelete: Cascade)
  createdBy      User?          @relation("BloodPressureCreator", fields: [createdById], references: [id], onDelete: SetNull)
}

model MedicineImage {
  id           String         @id @default(cuid())
  elderlyId    String
  imageUrl     String
  label        String?
  uploadedById String?
  uploadedAt   DateTime       @default(now())
  elderly      ElderlyProfile @relation(fields: [elderlyId], references: [id], onDelete: Cascade)
  uploadedBy   User?          @relation("MedicineUploader", fields: [uploadedById], references: [id], onDelete: SetNull)
  aiScans      AiScan[]
}

model AiScan {
  id              String         @id @default(cuid())
  elderlyId       String
  medicineImageId String?
  scanType        AiScanType
  imageUrl        String
  extractedText   String?
  status          AiScanStatus   @default(PENDING)
  rawResult       Json?
  summary         String?
  confidence      Float?
  reviewedById    String?
  reviewedAt      DateTime?
  createdAt       DateTime       @default(now())
  elderly         ElderlyProfile @relation(fields: [elderlyId], references: [id], onDelete: Cascade)
  medicineImage   MedicineImage? @relation(fields: [medicineImageId], references: [id], onDelete: SetNull)
  reviewedBy      User?          @relation("AiScanReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String
  entityType String
  entityId   String
  meta       Json?
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model ChatMessage {
  id         String   @id @default(cuid())
  elderlyId  String
  senderId   String
  senderRole Role
  content    String
  createdAt  DateTime @default(now())

  elderly ElderlyProfile @relation(fields: [elderlyId], references: [id], onDelete: Cascade)
  sender  User           @relation("ChatSender", fields: [senderId], references: [id], onDelete: Cascade)
}

model AiHealthMessage {
  id        String              @id @default(cuid())
  elderlyId String
  role      AiHealthMessageRole
  content   String
  createdAt DateTime            @default(now())

  elderly ElderlyProfile @relation(fields: [elderlyId], references: [id], onDelete: Cascade)
}

/* NextAuth tables */
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
